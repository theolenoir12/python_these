     plt.rcParams.update({"font.family": "serif", "mathtext.fontset": "cm",
         "axes.labelsize": 15, "legend.fontsize": 9.5, "xtick.labelsize": 12,
@@ -108,6 +123,8 @@ def main():
         "MPC (H=24)": ("tab:red", "s"), "MPC (H=48)": ("tab:orange", "s"),
