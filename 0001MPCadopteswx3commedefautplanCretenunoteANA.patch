     if dp is not None:
         ax1.plot(dp[:, 0], dp[:, 1], "-", color="0.4", lw=1.6, zorder=1,
                  label="Front DP (borne offline)")
@@ -126,6 +143,8 @@ def main():
     lines = {"RB2 socle": ("tab:blue", "-"), "RB2(SoH_all) (test nul)": ("tab:cyan", "-"),
              "RB2(SoH_all+Pred)": ("tab:green", "-"), "MPC (H=24)": ("tab:red", "-"),
