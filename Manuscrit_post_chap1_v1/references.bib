	langid = {english},
	file = {Ibrahim et al. - 2021 - An overview of supercapacitors for integrated PV –.pdf:C\:\\Users\\tlenoi01\\Zotero\\storage\\8DLWVM9T\\Ibrahim et al. - 2021 - An overview of supercapacitors for integrated PV –.pdf:application/pdf},
