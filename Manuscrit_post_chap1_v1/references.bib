	urldate = {2024-06-13},
	date = {2020-10},
	note = {{ISSN}: 2577-1647},
	keywords = {Aging, Degradation, health indicator, Load modeling, prognostics, Prognostics and health management, proton exchange membrane fuel cell, remaining useful life, Resistance, Steady-state, Voltage measurement},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\tlenoi01\\Zotero\\storage\\PR4TGX2H\\figures.html:text/html;IEEE Xplore Full Text PDF:C\:\\Users\\tlenoi01\\Zotero\\storage\\RPSXZ7SF\\Hua et al. - 2020 - Health Indicators for PEMFC Systems Life Predictio.pdf:application/pdf},
