	keywords = {Proton exchange membrane fuel cell, State of health, Analytical equivalent circuit model, Electrochemical impedance spectroscopy},
	file = {ScienceDirect Snapshot:C\:\\Users\\tlenoi01\\Zotero\\storage\\XXUC5H9X\\S0360544220312925.html:text/html},
}

@inproceedings{shen_online_2019,
