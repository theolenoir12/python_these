	keywords = {Discharges (electric), Estimation, extended kalman filter, Kalman filters, Lead acid batteries, Mathematical model, particle filter, Particle filters, state-of-health, unscented kalman filter, {VRLA} battery},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\tlenoi01\\Zotero\\storage\\WDLF73L9\\figures.html:text/html;IEEE Xplore Full Text PDF:C\:\\Users\\tlenoi01\\Zotero\\storage\\CBIKBTKV\\Sedighfar et Moniri - 2018 - Comparison of Three Well-known Filters for the Bat.pdf:application/pdf},
