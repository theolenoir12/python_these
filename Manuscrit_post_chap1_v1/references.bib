@article{zhou_equivalent_2020,
	title = {Equivalent Consumption Minimization Strategy With Consideration of Battery Aging for Parallel Hybrid Electric Vehicles},
	volume = {8},
	issn = {2169-3536},
	url = {https://ieeexplore.ieee.org/document/9249025},
	doi = {10.1109/ACCESS.2020.3036033},
	abstract = {The equivalent consumption minimization strategy ({ECMS}) is a well-known energy management strategy for Hybrid Electric Vehicles ({HEV}). {ECMS} is very computationally efficient since it yields an instantaneous optimal control. {ECMS} has been shown to minimize fuel consumption under certain conditions. But, minimizing the fuel consumption often leads to excessive battery damage. This paper introduces a new optimal control problem where the cost function includes terms for both fuel consumption and battery aging. The Ah-throughput method is used to quantify battery aging. {ECMS} (with the appropriate equivalence factor) is shown to also minimize the cost function that incorporates battery aging. Simulation results show that the proposed aging {ECMS} algorithm significantly improves battery aging with little or no fuel economy penalty compared to ordinary {ECMS}.},
	pages = {204770--204781},
	journaltitle = {{IEEE} Access},
	author = {Zhou, Bin and Burl, Jeffrey B. and Rezaei, Amir},
	urldate = {2025-11-07},
	date = {2020},
	keywords = {Aging, Batteries, Battery aging, Electronic countermeasures, energy management strategies, equivalent consumption minimization strategy, hybrid electric vehicle, Hybrid electric vehicles, Integrated circuit modeling, optimal control, State of charge, Vehicles},
}

@article{du_optimization_2022,
	title = {Optimization of Energy Management Strategy for Fuel Cell Hybrid Electric Vehicles Based on Dynamic Programming},
