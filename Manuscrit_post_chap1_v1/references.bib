Publisher: Multidisciplinary Digital Publishing Institute},
	keywords = {electric traction drives, electrical vehicle, energy storage system, microgrid, renewable energy, supercapacitors},
	file = {Full Text PDF:C\:\\Users\\tlenoi01\\Zotero\\storage\\U2FFPP7A\\Navarro et al. - 2021 - Present and Future of Supercapacitor Technology Ap.pdf:application/pdf},
