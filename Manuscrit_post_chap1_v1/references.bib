@article{cho_effects_2004,
	title = {Effects of Water Removal on the Performance Degradation of {PEMFCs} Repetitively Brought to  {\textless} 0 \textdegree  C},
	volume = {151},
	url = {https://iopscience.iop.org/article/10.1149/1.1683580},
	doi = {10.1149/1.1683580},
	abstract = {For the mobile application, performance of polymer electrolyte membrane fuel cells ({PEMFCs}) should be maintained with being exposed to subzero temperatures in the winter time. To simulate the situation, a {PEMFC} was operated at 80°C, stopped, cooled to and kept at -10°C for 1 h, and heated to 80°C for the next operation. With the thermal cycle, cell performance was measured and found to degrade at a degradation rate of 2.3\% based on current density at a cell voltage of 0.6 V. The degradation was attributed to freezing of water that was produced during operation and remained in the {PEMFC} after the operation. To prevent the performance degradation, water was removed from the {PEMFC} by supplying dry gases or an antifreeze solution to the {PEMFC} before the cell temperature fell to below 0°C, By using the gas-purging and the solution-purging method designed in this work, the performance degradation rate was successfully reduced to 0.06 and -0.47\%, respectively. © 2004 The Electrochemical Society. All rights reserved.},
	pages = {A661--A661},
	number = {5},
	journaltitle = {Journal of The Electrochemical Society},
	publisher = {{IOP} Publishing},
	author = {Cho, {EunAe} and Ko, Jae-Joon and Ha, Heung Yong and Hong, Seong-Ahn and Lee, Kwan-Young and Lim, Tae-Won and Oh, In-Hwan},
	date = {2004-03},
}

@article{villagra_analysis_2019,
	title = {An analysis of {PEM} water electrolysis cells operating at elevated current densities},
	volume = {44},
	url = {https://www.sciencedirect.com/science/article/pii/S0360319918338400?via%3Dihub},
	doi = {10.1016/J.IJHYDENE.2018.11.179},
	abstract = {Recent developments related to the operation of {PEM} water electrolysis cells at elevated current density are reported. First, a cost analysis has been performed to discuss the interest of extending the range of operating current density of these cells, towards the 10 A cm−2 range and above. Then the technical impact this may have on the cell design has been analyzed, and the practical conditions required to remove the extra-heat and to facilitate fluid transport across the porous transport layers have been identified. Experimental current-voltage polarization curves have been measured using a pressurized laboratory cells equipped with {PFSA} (perfluoro-sulfonic acid) membranes of various thicknesses, operating at 80 °C and current densities up to 10 A cm−2. These experimental polarization curves have been fitted using model equations. Key cell parameters such as internal cell resistance, charge transfer exchange current densities and roughness factors have been determined from these fits. The impact of the cell design on the performance and efficiency of {PEM} water electrolysis cells operated in the multi A cm−2 range of current density has been analyzed, with a focus on the situation that prevails above 5 A cm−2.},
	pages = {9708--9717},
	number = {20},
	journaltitle = {International Journal of Hydrogen Energy},
	publisher = {Pergamon},
	author = {Villagra, A. and Millet, P.},
	date = {2019-04},
	keywords = {Hydrogen, Water electrolysis, Oxygen, Large current density, Polymer electrolyte},
}

@article{fouda-onana_investigation_2016,
	title = {Investigation on the degradation of {MEAs} for {PEM} water electrolysers part I: Effects of testing conditions on {MEA} performances and membrane properties},
	volume = {41},
	url = {https://www.sciencedirect.com/science/article/pii/S0360319916321164?via%3Dihub},
	doi = {10.1016/J.IJHYDENE.2016.07.125},
	abstract = {Proton exchange membrane water electrolyzer ({PEM} {WE}) is an attractive electrochemical device that generates high purity hydrogen. However, its insufficient durability relatively to its high system cost is a bottleneck of that technology when compared to alkaline water electrolysis. In this work, the influence of the ageing protocols on {PEM} {WE} performances is investigated. From electrochemical and physico-chemical analyses it was found that high temperature degrades the membrane more than the current density does. High F− content from the perfluorosulfonic acid ({PFSA}) membrane degradation was found on the cathode side. Such a result supports the 2 e− oxygen reduction reaction mechanism that generates hydrogen peroxide which is known as detrimental compound for the {PFSA} membranes. The monitoring of the fluoride rate might be a suitable parameter to estimate the membrane thickness change. In our test conditions at 80 °C the membrane thinning rate was found to be 25 nm/h using {SEM} images which was twice the value found from fluoride measurements.},
	pages = {16627--16636},
	number = {38},
	journaltitle = {International Journal of Hydrogen Energy},
	publisher = {Pergamon},
	author = {Fouda-Onana, F. and Chandesris, M. and Médeau, V. and Chelghoum, S. and Thoby, D. and Guillet, N.},
	date = {2016-10},
	keywords = {Ageing, {PEM} water electrolysis, Fluoride release, Membrane thinning},
}

