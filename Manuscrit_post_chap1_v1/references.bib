	note = {Number: 12
Publisher: Multidisciplinary Digital Publishing Institute},
	keywords = {state of health ({SOH}), attention mechanism (Attention), bidirectional long short-term memory network ({BiLSTM}), convolutional neural network ({CNN}), multi-step prediction},
