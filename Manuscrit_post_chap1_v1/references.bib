	title = {Novel components in Proton Exchange Membrane ({PEM}) Water Electrolyzers ({PEMWE}): Status, challenges and future needs. A mini review},
	volume = {114},
	url = {https://www.sciencedirect.com/science/article/pii/S1388248120300552},
