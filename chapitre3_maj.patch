+def darken(color, factor=0.7):
+    r, g, b = mcolors.to_rgb(color)
+    h, l, s = colorsys.rgb_to_hls(r, g, b)
+    return colorsys.hls_to_rgb(h, max(0.0, l * factor), s)
+
+
+def color_of(label):
