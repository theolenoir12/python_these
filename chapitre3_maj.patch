+    n = len(lpsp)
+    keep = np.ones(n, dtype=bool)
+    for i in range(n):
+        for j in range(n):
+            if i != j and lpsp[j] <= lpsp[i] and deg[j] <= deg[i] and (
+                    lpsp[j] < lpsp[i] or deg[j] < deg[i]):
+                keep[i] = False
+                break
+    o = np.argsort(lpsp[keep])
+    return lpsp[keep][o], deg[keep][o]
+
