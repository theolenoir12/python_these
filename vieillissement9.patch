+    ax.set_xlabel("LPSP [%]"); ax.set_ylabel("Coût total de dégradation [k€]")
+    ax.set_title("RB2(SoH) — min dégradation sous contrainte LPSP (25 ans)\n"
+                 "zone admissible = à gauche de la ligne rouge")
