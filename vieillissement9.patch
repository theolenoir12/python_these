+    ax.plot(lpsp_v, cost_v, 'k--', lw=1.5, alpha=0.5, zorder=3)
+    cbar = plt.colorbar(sc, ax=ax)
+    cbar.set_label(r'$\varepsilon$', fontsize=14)
