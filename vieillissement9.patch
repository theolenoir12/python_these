+    # ÉTAPE 1 : Faire tourner le code
+    data = init_and_run_loop(get_optimal_action_RB)
+
+    # ÉTAPE 2 : Visualisation et résultats
+    run_main_plot(data)
+
+    end_time = timer()
+    print(f"--- Simulation terminée en {end_time - start_time:.2f} s ---")
+
+if __name__ == "__main__":
+    main()
